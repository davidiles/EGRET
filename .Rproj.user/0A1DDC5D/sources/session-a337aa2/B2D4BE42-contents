# ==============================================================================
# 06_final_processing.R
#
# Prepare final hexagon x species dataset for impact assessment export
# ==============================================================================

library(tidyverse)
library(sf)

rm(list = ls())

source("R/config.R")
source("R/functions_new.R")

dir.create(OUT_CACHE, recursive = TRUE, showWarnings = FALSE)

# ------------------------------------------------------------------------------
# Input paths
# ------------------------------------------------------------------------------

combined_data_path <- file.path(
  OUT_CACHE,
  "hex_species_abundance_categories_ebird_bam.rds"
)

hex_grid_path <- file.path(
  OUT_CACHE,
  paste0("hex_grid_national_", HEX_WIDTH_KM, "_km.rds")
)

# ------------------------------------------------------------------------------
# Output paths
# ------------------------------------------------------------------------------

final_data_path <- file.path(
  OUT_CACHE,
  "final_hex_species_impact_assessment_dataset.rds"
)

final_data_csv_path <- file.path(
  OUT_CACHE,
  "final_hex_species_impact_assessment_dataset.csv"
)

final_data_gpkg_path <- file.path(
  OUT_CACHE,
  "final_hex_species_impact_assessment_dataset.gpkg"
)

# ------------------------------------------------------------------------------
# Load combined species x hexagon dataset
# ------------------------------------------------------------------------------

if (!file.exists(combined_data_path)) {
  stop(
    "Combined hex-species dataset does not exist: ", combined_data_path, "\n",
    "Run script 05 first."
  )
}

dat_to_save <- readRDS(combined_data_path)

stopifnot("hex_id" %in% names(dat_to_save))

message("Loaded combined dataset with ", nrow(dat_to_save), " rows.")
message("Species: ", dplyr::n_distinct(dat_to_save$english_name))
message("Hexagons: ", dplyr::n_distinct(dat_to_save$hex_id, na.rm = TRUE))

# ------------------------------------------------------------------------------
# Load national hexagon grid
# ------------------------------------------------------------------------------

if (!file.exists(hex_grid_path)) {
  stop(
    "Hex grid does not exist: ", hex_grid_path, "\n",
    "Run scripts/01_create_national_hex_grid.R first."
  )
}

hex_grid_national <- readRDS(hex_grid_path)

stopifnot(inherits(hex_grid_national, "sf"))
stopifnot("hex_id" %in% names(hex_grid_national))
stopifnot("hex_area_km2" %in% names(hex_grid_national))

message("Loaded hex grid with ", nrow(hex_grid_national), " hexagons.")

# ------------------------------------------------------------------------------
# Join geometry to final dataset
# ------------------------------------------------------------------------------

final_dat_sf <- dat_to_save |>
  left_join(
    hex_grid_national |>
      select(hex_id, hex_area_km2, geometry),
    by = "hex_id"
  ) |>
  sf::st_as_sf()

stopifnot(inherits(final_dat_sf, "sf"))

message("Final spatial dataset rows: ", nrow(final_dat_sf))