# Section 9 – Diagnostic threshold helpers
# ==============================================================================

resolve_effort_threshold <- function(n_surveys,
                                     effort_min_surveys = NULL,
                                     effort_quantile    = NULL) {
  surveyed_n <- n_surveys[!is.na(n_surveys) & n_surveys > 0]

  if (!is.null(effort_min_surveys)) return(as.integer(effort_min_surveys))

  if (!is.null(effort_quantile) && length(surveyed_n) >= 4) {
    return(as.integer(ceiling(stats::quantile(
      surveyed_n, probs = effort_quantile, na.rm = TRUE
    ))))
  }

  1L
}


#' Add cumulative-population and density-based diagnostic classes
#'
#' Classifies hexagons as "high abundance" or "effectively absent" based on
#' where they fall in the predicted-abundance distribution.  Reads
#' \code{hex_area_m2} from precomputed columns when available to avoid
#' repeated \code{sf::st_area()} calls.
add_cumulative_prediction_classes <- function(hex_summary,
                                              min_coverage             = 0.25,
                                              high_pred_cumprop        = 0.50,
                                              high_pred_threshold      = NULL,
                                              absence_fraction_of_high = 0.01,
                                              absence_threshold        = NULL) {
  stopifnot(inherits(hex_summary, "sf"))
  stopifnot("hex_id"        %in% names(hex_summary))
  stopifnot("pred_mean"     %in% names(hex_summary))
  stopifnot("pred_coverage" %in% names(hex_summary))

  if (!is.null(high_pred_cumprop)) {
    stopifnot(
      is.numeric(high_pred_cumprop), length(high_pred_cumprop) == 1,
      is.finite(high_pred_cumprop), high_pred_cumprop > 0,
      high_pred_cumprop <= 1
    )
  }
  if (!is.null(absence_fraction_of_high)) {
    stopifnot(
      is.numeric(absence_fraction_of_high),
      length(absence_fraction_of_high) == 1,
      is.finite(absence_fraction_of_high),
      absence_fraction_of_high >= 0
    )
  }

  # Use precomputed area when available; fall back to sf::st_area()
  hex_area <- if ("hex_area_m2" %in% names(hex_summary)) {
    hex_summary$hex_area_m2
  } else {
    as.numeric(sf::st_area(hex_summary))
  }

  study_area_coverage <- if ("study_area_coverage" %in% names(hex_summary)) {
    dplyr::coalesce(hex_summary$study_area_coverage, 0)
  } else {
    rep(1, nrow(hex_summary))
  }

  dat <- hex_summary %>%
    dplyr::mutate(
      valid_pred_for_threshold =
        is.finite(pred_mean) &
        !is.na(pred_coverage) &
        pred_coverage >= min_coverage,
      pred_population_area  = hex_area * pmax(study_area_coverage, 0),
      pred_population_index = dplyr::if_else(
        valid_pred_for_threshold,
        pmax(pred_mean, 0) * pred_population_area,
        NA_real_
      )
    )

  total_pred_population <- sum(dat$pred_population_index, na.rm = TRUE)

  cumulative_high_pred_threshold <- NA_real_
  relative_absence_threshold     <- NA_real_
  n_high_pred_reference_hex      <- 0L
  pred_population_in_high_tail   <- NA_real_

  dat$pred_population_prop      <- NA_real_
  dat$cum_pred_prop_high_to_low <- NA_real_
  dat$in_high_cumulative_tail   <- FALSE

  if (is.finite(total_pred_population) && total_pred_population > 0) {

    rank_dat <- dat %>%
      sf::st_drop_geometry() %>%
      dplyr::select(hex_id, pred_mean, pred_population_index) %>%
      dplyr::filter(is.finite(pred_population_index)) %>%
      dplyr::mutate(
        pred_population_prop = pred_population_index / total_pred_population
      )

    high_rank <- rank_dat %>%
      dplyr::arrange(dplyr::desc(pred_mean), hex_id) %>%
      dplyr::mutate(
        cum_pred_prop_high_to_low = cumsum(pred_population_prop),
        cum_pred_prop_high_to_low_lag = dplyr::lag(
          cum_pred_prop_high_to_low, default = 0
        ),
        in_high_cumulative_tail = if (!is.null(high_pred_cumprop)) {
          cum_pred_prop_high_to_low_lag < high_pred_cumprop
        } else {
          FALSE
        }
      ) %>%
      dplyr::select(
        hex_id, pred_population_prop,
        cum_pred_prop_high_to_low, in_high_cumulative_tail
      )

    dat <- dat %>%
      dplyr::select(
        -pred_population_prop,
        -cum_pred_prop_high_to_low,
        -in_high_cumulative_tail
      ) %>%
      dplyr::left_join(high_rank, by = "hex_id") %>%
      dplyr::mutate(
        in_high_cumulative_tail = dplyr::coalesce(in_high_cumulative_tail,
                                                  FALSE)
      )

    high_tail <- dat %>%
      sf::st_drop_geometry() %>%
      dplyr::filter(in_high_cumulative_tail)

    n_high_pred_reference_hex    <- nrow(high_tail)
    pred_population_in_high_tail <- sum(high_tail$pred_population_prop,
                                        na.rm = TRUE)

    if (n_high_pred_reference_hex > 0) {
      cumulative_high_pred_threshold <- min(high_tail$pred_mean, na.rm = TRUE)
    }
  }

  high_pred_candidates <- c(cumulative_high_pred_threshold, high_pred_threshold)
  high_pred_candidates <- high_pred_candidates[is.finite(high_pred_candidates)]
  resolved_high_pred_threshold <- if (length(high_pred_candidates) > 0)
    max(high_pred_candidates) else NA_real_

  if (is.finite(resolved_high_pred_threshold)) {
    relative_absence_threshold <- absence_fraction_of_high *
      resolved_high_pred_threshold
  }

  absence_candidates <- c(relative_absence_threshold, absence_threshold)
  absence_candidates <- absence_candidates[is.finite(absence_candidates)]
  resolved_absence_threshold <- if (length(absence_candidates) > 0)
    max(absence_candidates) else NA_real_

  out <- dat %>%
    dplyr::mutate(
      effectively_absent =
        is.finite(resolved_absence_threshold) &
        is.finite(pred_mean) &
        !is.na(pred_coverage) &
        pred_coverage >= min_coverage &
        pred_mean <= resolved_absence_threshold,

      high_abundance =
        is.finite(resolved_high_pred_threshold) &
        is.finite(pred_mean) &
        pred_coverage >= min_coverage &
        pred_mean >= resolved_high_pred_threshold
    )

  attr(out, "flag_thresholds") <- list(
    high_pred_cumprop              = high_pred_cumprop,
    high_pred_cumulative_threshold = cumulative_high_pred_threshold,
    high_pred_absolute_threshold   = high_pred_threshold,
    high_pred_threshold            = resolved_high_pred_threshold,
    n_high_pred_reference_hex      = n_high_pred_reference_hex,
    pred_population_in_high_tail   = pred_population_in_high_tail,
    absence_fraction_of_high       = absence_fraction_of_high,
    absence_relative_threshold     = relative_absence_threshold,
    absence_absolute_threshold     = absence_threshold,
    absence_threshold              = resolved_absence_threshold,
    min_coverage                   = min_coverage,
    total_pred_population_index    = total_pred_population
  )

  out
}


