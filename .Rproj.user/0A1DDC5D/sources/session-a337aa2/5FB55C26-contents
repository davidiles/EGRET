#' @export
plot_hex_pred_obs <- function(hex_summary,
                              rast,
                              study_area,
                              water                           = NULL,
                              rast_max_q                      = 0.99,
                              max_count_per_effort            = NULL,
                              palette                         = NULL,
                              circle_fill                     = "black",
                              water_fill                      = "#b8dceb",
                              transform                       = "identity",
                              min_coverage                    = 0.25,
                              min_study_area_coverage         = 0.50,
                              flag_high_pred_cumprop          = 0.50,
                              flag_high_pred_threshold        = NULL,
                              flag_high_pred_min_surveys      = 50,
                              flag_high_pred_effort_quantile  = NULL,
                              flag_absence_fraction_of_high   = 0.01,
                              flag_absence_threshold          = NULL,
                              flag_absence_min_surveys        = 1,
                              flag_absence_effort_quantile    = NULL,
                              flag_col_high_pred_no_detection = "red",
                              flag_col_pred_absent_detected   = "blue",
                              flag_linewidth                  = 0.8,
                              flag_fill_alpha                 = 0.1) {

  stopifnot(inherits(hex_summary, "sf"))
  stopifnot(inherits(rast,        "SpatRaster"))
  stopifnot(inherits(study_area,  "sf"))
  stopifnot("mean_count_per_effort" %in% names(hex_summary))
  stopifnot("n_surveys"             %in% names(hex_summary))

  if (!"pred_mean" %in% names(hex_summary)) {
    hex_summary <- extract_hex_predictions(hex_summary, rast,
                                           rast_max_q   = rast_max_q,
                                           min_coverage = min_coverage)
  }

  if (!"study_area_coverage" %in% names(hex_summary)) {
    hex_summary <- add_study_area_coverage(hex_summary, study_area)
  }

  if (is.null(palette)) {
    palette <- grDevices::colorRampPalette(c(
      "#FBF7E2", "#FCF8D0", "#EEF7C2", "#CEF2B0",
      "#94E5A0", "#51C987", "#18A065", "#008C59",
      "#007F53", "#006344"
    ))(100)
  }

  water_to_plot <- NULL
  if (!is.null(water)) {
    stopifnot(inherits(water, "processed_water"))
    plot_crs    <- water$crs
    study_area  <- sf::st_transform(study_area,  plot_crs)
    hex_summary <- sf::st_transform(hex_summary, plot_crs)
    rast        <- terra::project(rast, plot_crs$wkt)
    water_to_plot <- resolve_water_layer(water, study_area)
  } else {
    plot_crs    <- sf::st_crs(hex_summary)
    study_area  <- sf::st_transform(study_area,  plot_crs)
    hex_summary <- sf::st_transform(hex_summary, plot_crs)
    rast        <- terra::project(rast, plot_crs$wkt)
  }

  rast_display <- terra::crop(rast, terra::vect(study_area)) %>%
    terra::mask(terra::vect(study_area))

  r_max <- as.numeric(stats::quantile(
    terra::values(rast_display)[terra::values(rast_display) > 0],
    rast_max_q, na.rm = TRUE
  ))
  if (!is.finite(r_max) || r_max <= 0) r_max <- 1
  rast_display <- terra::clamp(rast_display, upper = r_max, values = TRUE)

  rast_df           <- as.data.frame(rast_display, xy = TRUE, na.rm = FALSE)
  names(rast_df)[3] <- "value"
  rast_zero    <- dplyr::filter(rast_df, !is.na(value) & value == 0)
  rast_nonzero <- dplyr::filter(rast_df, !is.na(value) & value  > 0)

  # Cumulative abundance / absence classification
  hex_summary <- add_cumulative_prediction_classes(
    hex_summary              = hex_summary,
    min_coverage             = min_coverage,
    high_pred_cumprop        = flag_high_pred_cumprop,
    high_pred_threshold      = flag_high_pred_threshold,
    absence_fraction_of_high = flag_absence_fraction_of_high,
    absence_threshold        = flag_absence_threshold
  )
  abundance_thresholds <- attr(hex_summary, "flag_thresholds")

  resolved_min_surveys_high_pred <- resolve_effort_threshold(
    n_surveys          = hex_summary$n_surveys,
    effort_min_surveys = flag_high_pred_min_surveys,
    effort_quantile    = flag_high_pred_effort_quantile
  )
  resolved_min_surveys_absence <- resolve_effort_threshold(
    n_surveys          = hex_summary$n_surveys,
    effort_min_surveys = flag_absence_min_surveys,
    effort_quantile    = flag_absence_effort_quantile
  )

  hex_summary <- hex_summary %>%
    dplyr::mutate(
      obs_detected_flag = dplyr::coalesce(obs_detected, FALSE),

      flag_high_pred_no_detection =
        high_abundance &
        study_area_coverage >= min_study_area_coverage &
        n_surveys >= resolved_min_surveys_high_pred &
        !obs_detected_flag,

      flag_pred_absent_detected =
        effectively_absent &
        pred_coverage > 0 &
        n_surveys >= resolved_min_surveys_absence &
        n_surveys_detected >= 2 &
        obs_detected_flag,

      inconsistency_class = dplyr::case_when(
        flag_high_pred_no_detection ~ "High predicted, not detected",
        flag_pred_absent_detected   ~ "Predicted absent, detected",
        TRUE                        ~ NA_character_
      )
    )

  flag_sf <- hex_summary %>%
    dplyr::filter(flag_high_pred_no_detection | flag_pred_absent_detected) %>%
    dplyr::mutate(
      flag_type = dplyr::case_when(
        flag_high_pred_no_detection ~ "High predicted,\nnot detected",
        flag_pred_absent_detected   ~ "Predicted absent,\ndetected",
        TRUE                        ~ NA_character_
      )
    )

  n_flag_high_pred_no_detection <- sum(
    hex_summary$flag_high_pred_no_detection, na.rm = TRUE
  )
  n_flag_pred_absent_detected <- sum(
    hex_summary$flag_pred_absent_detected, na.rm = TRUE
  )

  if (is.null(max_count_per_effort)) {
    detected <- hex_summary$mean_count_per_effort[
      !is.na(hex_summary$mean_count_per_effort) &
        hex_summary$mean_count_per_effort > 0
    ]
    max_count_per_effort <- if (length(detected) == 0) 1 else
      as.numeric(stats::quantile(detected, probs = 0.99, na.rm = TRUE))
  }
  if (!is.finite(max_count_per_effort) || max_count_per_effort <= 0) {
    max_count_per_effort <- 1
  }

  # Use precomputed inner diameter when available
  inner_diameter <- if ("hex_inner_diameter_m" %in% names(hex_summary)) {
    hex_summary$hex_inner_diameter_m
  } else {
    hex_area <- as.numeric(sf::st_area(hex_summary))
    2 * sqrt(hex_area / (2 * sqrt(3)))
  }

  circle_sf <- hex_summary %>%
    dplyr::mutate(
      mean_count_per_effort = dplyr::coalesce(mean_count_per_effort, 0),
      n_surveys             = dplyr::coalesce(n_surveys, 0L),
      count_scaled          = pmin(mean_count_per_effort,
                                   max_count_per_effort) / max_count_per_effort,
      circle_diameter = dplyr::if_else(
        mean_count_per_effort > 0 & n_surveys > 0,
        0.1 * inner_diameter +
          sqrt(count_scaled) * (0.6 - 0.1) * inner_diameter,
        0
      ),
      circle_radius = circle_diameter / 2
    ) %>%
    sf::st_point_on_surface()

  xy        <- sf::st_coordinates(circle_sf)
  circle_df <- circle_sf %>%
    sf::st_drop_geometry() %>%
    dplyr::mutate(x = xy[, 1], y = xy[, 2])

  spearman_obs_pred_above_absence <- compute_filtered_spearman(
    hex_summary       = hex_summary,
    absence_threshold = abundance_thresholds$absence_threshold
  )

  corr_label <- paste0(
    "Spearman rho = ",
    ifelse(is.finite(spearman_obs_pred_above_absence),
           round(spearman_obs_pred_above_absence, 2), "NA"),
    "\nAbsence threshold <= ",
    signif(abundance_thresholds$absence_threshold, 3),
    "\nHigh threshold >= ",
    signif(abundance_thresholds$high_pred_threshold, 3),
    "\nHigh pred, no detection = ", n_flag_high_pred_no_detection,
    "\nPred absent, detected = ",   n_flag_pred_absent_detected
  )

  bbox    <- sf::st_bbox(study_area)
  corr_df <- data.frame(
    x     = bbox["xmax"] - 0.0001 * (bbox["xmax"] - bbox["xmin"]),
    y     = bbox["ymax"] - 0.0001 * (bbox["ymax"] - bbox["ymin"]),
    label = corr_label
  )

  flag_fill_colours <- c(
    "High predicted,\nnot detected" = flag_col_high_pred_no_detection,
    "Predicted absent,\ndetected"   = flag_col_pred_absent_detected
  )
  
  # Subset to only flag types present for this species — override.aes length
  # must match the number of legend keys, which equals the number of active
  # flag types when drop = FALSE is not in effect for the colour override.
  active_flag_types   <- intersect(
    names(flag_fill_colours),
    unique(flag_sf$flag_type)
  )
  active_flag_colours <- unname(flag_fill_colours[active_flag_types])
  

  p <- ggplot2::ggplot() +
    ggplot2::geom_sf(data = study_area, fill = "gray80", colour = NA) +
    ggplot2::geom_raster(data = rast_zero,
                         ggplot2::aes(x = x, y = y), fill = "white") +
    ggplot2::geom_raster(data = rast_nonzero,
                         ggplot2::aes(x = x, y = y, fill = value))

  if (!is.null(water_to_plot)) {
    p <- p + ggplot2::geom_sf(data = water_to_plot,
                              fill = water_fill, colour = water_fill,
                              linewidth = 0.1)
  }

  p <- p +
    ggplot2::scale_fill_gradientn(
      colours  = palette, limits = c(0, r_max),
      oob      = scales::squish, na.value = "transparent",
      trans    = transform, name = "Relative abundance",
      guide    = ggplot2::guide_colourbar(order = 1)
    ) +
    ggnewscale::new_scale_fill() +

    ggplot2::geom_sf(
      data  = subset(hex_summary, n_surveys > 0),
      fill  = NA, colour = "gray50", linewidth = 0.05, alpha = 0.1
    ) +
    ggplot2::geom_sf(
      data  = flag_sf,
      ggplot2::aes(fill = flag_type),
      colour = NA, alpha = flag_fill_alpha
    ) +
    ggplot2::scale_fill_manual(
      name   = "Diagnostic flags",
      values = flag_fill_colours,
      drop   = FALSE,
      guide  = ggplot2::guide_legend(
        order        = 2,
        override.aes = list(
          alpha     = flag_fill_alpha,
          linewidth = flag_linewidth + 0.3,
          colour    = active_flag_colours
        )
      )
    ) +
    ggplot2::geom_sf(
      data  = flag_sf,
      ggplot2::aes(colour = flag_type),
      fill  = NA, linewidth = flag_linewidth, show.legend = FALSE
    ) +
    ggplot2::scale_colour_manual(
      values = flag_fill_colours, drop = FALSE, guide = "none"
    ) +
    ggplot2::geom_sf(data = study_area, fill = NA, colour = "gray30", linewidth = 0.1) +
    ggforce::geom_circle(
      data = dplyr::filter(circle_df, circle_radius > 0),
      ggplot2::aes(x0 = x, y0 = y, r = circle_radius),
      alpha = 1, fill = circle_fill, colour = NA
    ) +
    ggspatial::annotation_scale(location = "br", width_hint = 0.25) +
    ggplot2::geom_label(
      data = corr_df,
      ggplot2::aes(x = x, y = y, label = label),
      hjust = 1, vjust = 1,
      fill = "white", colour = "black",
      label.size = 0, size = 6, family = "mono"
    ) +
    ggplot2::coord_sf() +
    ggplot2::theme_void() +
    ggplot2::theme(
      legend.position      = c(0.03, 0.03),
      legend.justification = c(0, 0),
      legend.background    = ggplot2::element_rect(fill = "white", colour = NA),
      legend.margin        = ggplot2::margin(4, 4, 4, 4),
      legend.box.margin    = ggplot2::margin(6, 6, 6, 6),
      plot.background      = ggplot2::element_rect(fill = "white",
                                                   colour = "black",
                                                   linewidth = 0.5),
      panel.background     = ggplot2::element_rect(fill = "white", colour = NA),
      plot.title    = ggplot2::element_text(size = 14, face = "bold", hjust = 0),
      plot.subtitle = ggplot2::element_text(size = 12, hjust = 0,
                                            margin = ggplot2::margin(b = 6))
    ) +
    ggplot2::labs(
      title    = "Predicted vs observed",
      subtitle = paste(
        "Raster fill = model predicted relative abundance",
        "Circle size = observed mean count in hexagon",
        "Bold outlines + fills = diagnostic flags",
        sep = "\n"
      )
    )

  list(
    plot        = p,
    hex_summary = hex_summary,
    spearman_obs_pred_above_absence = spearman_obs_pred_above_absence,
    flag_counts = data.frame(
      flag_high_pred_no_detection = n_flag_high_pred_no_detection,
      flag_pred_absent_detected   = n_flag_pred_absent_detected
    ),
    flag_thresholds = c(
      abundance_thresholds,
      list(
        high_pred_min_surveys     = resolved_min_surveys_high_pred,
        high_pred_effort_quantile = flag_high_pred_effort_quantile,
        absence_min_surveys       = resolved_min_surveys_absence,
        absence_effort_quantile   = flag_absence_effort_quantile,
        min_study_area_coverage   = min_study_area_coverage
      )
    )
  )
}


