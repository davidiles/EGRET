# ==============================================================================
# functions_optimized.R
#
# Core functions for BAM/eBird species distribution model validation.
# Compares model-predicted relative abundance against BAM point-count
# observations, summarised to a hexagonal grid.
#
# Dependencies: sf, terra, exactextractr, ggplot2, ggforce, ggspatial,
#               patchwork, dplyr, scales, ggnewscale, lubridate.
# All namespace calls are explicit so this file can be sourced directly or
# packaged without modification.
# ==============================================================================


# ==============================================================================
# Section 1 – Spatial setup helpers
# ==============================================================================

#' Remove interior holes from a MULTIPOLYGON sf object
#'
#' After \code{sf::st_union()} the national study-area boundary often contains
#' small interior holes (lakes, data artefacts).  This function strips all
#' holes, then drops sub-polygons smaller than \code{min_area_km2} to remove
#' tiny isolated fragments.
#'
#' This function was previously defined inline in each analysis script.
#' It is centralised here so any change propagates to both scripts.
#'
#' @param x           An \code{sf} object with a single MULTIPOLYGON geometry.
#' @param min_area_km2 Minimum area (km²) to retain after hole removal.
#' @return An \code{sf} MULTIPOLYGON with holes and small fragments removed.
#' @export
remove_multipolygon_holes <- function(x, min_area_km2 = 5) {
  g <- sf::st_geometry(x)[[1]]

  g_no_holes <- sf::st_multipolygon(
    lapply(g, function(poly) list(poly[[1]]))
  )

  sf::st_geometry(x) <- sf::st_sfc(g_no_holes, crs = sf::st_crs(x))

  x %>%
    sf::st_cast("POLYGON") %>%
    dplyr::mutate(area_km2 = as.numeric(sf::st_area(.) / 1e6)) %>%
    dplyr::filter(area_km2 > min_area_km2) %>%
    dplyr::summarise() %>%
    sf::st_cast("MULTIPOLYGON")
}


#' Derive a species-specific survey date window from eBird metadata
#'
#' Looks up \code{sp_english} in \code{ebirdst::ebirdst_runs} to find the
#' breeding-season start and end dates, then expands the window by
#' \code{buffer_days} on each side.  Falls back to \code{fallback_start} and
#' \code{fallback_end} if the species is absent from eBird or has no breeding
#' season dates.
#'
#' Both the BAM and eBird assessment scripts call this function so that the
#' survey date window is defined identically for the two models.
#'
#' @param sp_english     Common name of the species (must match eBird).
#' @param ebirdst_runs   The \code{ebirdst::ebirdst_runs} data frame.
#' @param buffer_days    Integer. Days to add/subtract around the window.
#' @param fallback_start ISO date string used when no eBird data are found.
#' @param fallback_end   ISO date string used when no eBird data are found.
#' @return A named list with elements \code{start_date}, \code{end_date},
#'   \code{start_doy}, \code{end_doy}, and \code{date_label}.
#' @export
get_species_date_window <- function(sp_english,
                                    ebirdst_runs,
                                    buffer_days    = 7L,
                                    fallback_start = "2023-06-01",
                                    fallback_end   = "2023-07-15") {

  ebird_row <- ebirdst_runs %>%
    dplyr::filter(common_name == sp_english) %>%
    dplyr::slice(1)

  if (nrow(ebird_row) > 0 && !is.na(ebird_row$breeding_start)) {
    start_date <- ebird_row$breeding_start
    end_date   <- ebird_row$breeding_end
  } else {
    start_date <- fallback_start
    end_date   <- fallback_end
  }

  start_doy <- lubridate::yday(as.Date(start_date)) - buffer_days
  end_doy   <- lubridate::yday(as.Date(end_date))   + buffer_days

  fmt_date <- function(d) {
    paste(
      format(as.Date(d), "%B"),
      as.integer(format(as.Date(d), "%d"))
    )
  }
  date_label <- paste(fmt_date(start_date), "to", fmt_date(end_date))

  list(
    start_date = start_date,
    end_date   = end_date,
    start_doy  = start_doy,
    end_doy    = end_doy,
    date_label = date_label
  )
}


# ==============================================================================
# Section 2 – Species data extraction
# ==============================================================================

#' Extract species-specific count data from a pre-filtered survey sf object
#'
#' Selects only the columns needed for a single species and computes
#' \code{count_per_effort} (detections per survey-hour).  Retains the
#' precomputed \code{hex_id} column so that downstream functions skip the
#' expensive per-species spatial join.
#'
#' @param survey_sf An \code{sf} POINT object containing all species columns
#'   (output of the BAM data filtering step).
#' @param spcd      Four-letter BAM species code (column name in
#'   \code{survey_sf}).
#' @return An \code{sf} object with columns \code{survey_datetime},
#'   \code{count}, \code{duration}, \code{hex_id}, and
#'   \code{count_per_effort}.
#' @export
make_sp_dat <- function(survey_sf, spcd) {
  survey_sf %>%
    dplyr::select(
      survey_datetime,
      dplyr::all_of(spcd),
      duration,
      hex_id
    ) %>%
    dplyr::rename(count = dplyr::all_of(spcd)) %>%
    dplyr::mutate(count_per_effort = count / (duration / 60))
}


