#' Clamp raster values below a lower bound to zero
#'
#' @param rast        A \code{SpatRaster}.
#' @param lower_bound Numeric scalar; values strictly below this are set to 0.
#' @return The modified \code{SpatRaster}.
apply_raster_lower_bound <- function(rast, lower_bound) {
  stopifnot(inherits(rast, "SpatRaster"))
  stopifnot(is.numeric(lower_bound), length(lower_bound) == 1,
            is.finite(lower_bound))
  rast[rast < lower_bound] <- 0
  rast
}


