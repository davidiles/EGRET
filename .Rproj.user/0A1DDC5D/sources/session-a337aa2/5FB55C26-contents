# Section 4 – Hexagonal grid construction and metadata
# ==============================================================================

#' Create a hexagonal grid over a study area
#'
#' After creation, call \code{precompute_hex_metadata()} once to attach
#' per-hexagon area, inner diameter, and study-area coverage so those
#' quantities are not recomputed on every species iteration.
#'
#' @param study_area   An \code{sf} polygon defining the grid extent.
#' @param n_hexagons   Target number of hexagons (used when
#'   \code{hex_width_km} is \code{NULL}).
#' @param hex_width_km Side-to-side hexagon width in kilometres.  Takes
#'   priority over \code{n_hexagons} when both are supplied.
#' @param work_crs     EPSG code of a planar CRS used during grid creation.
#'   Default 3978 (NAD83 / Canada Atlas Lambert).
#' @return An \code{sf} polygon object with a \code{hex_id} integer column.
#' @export
make_hex_grid <- function(study_area,
                          n_hexagons   = 200,
                          hex_width_km = NULL,
                          work_crs     = 3978) {
  stopifnot(inherits(study_area, "sf"))

  if (!is.null(hex_width_km) && !is.null(n_hexagons)) {
    message("Using `hex_width_km`; ignoring `n_hexagons`.")
  }

  old_s2 <- sf::sf_use_s2()
  on.exit(sf::sf_use_s2(old_s2), add = TRUE)
  sf::sf_use_s2(FALSE)

  original_crs    <- sf::st_crs(study_area)
  study_area_work <- sf::st_transform(study_area, work_crs) %>%
    sf::st_make_valid() %>%
    sf::st_collection_extract("POLYGON") %>%
    sf::st_buffer(0)

  study_area_union <- sf::st_union(study_area_work)

  hex_cellsize <- if (!is.null(hex_width_km)) {
    hex_width_km * 1000
  } else {
    target_area <- as.numeric(sf::st_area(study_area_union)) / n_hexagons
    sqrt(target_area / (sqrt(3) / 2))
  }

  hex_grid <- sf::st_make_grid(
    study_area_union,
    cellsize = hex_cellsize,
    square   = FALSE,
    what     = "polygons"
  )

  hex_sf <- sf::st_sf(
    hex_id   = seq_along(hex_grid),
    geometry = hex_grid,
    crs      = sf::st_crs(study_area_work)
  )

  keep          <- lengths(sf::st_intersects(hex_sf, study_area_union)) > 0
  hex_sf        <- hex_sf[keep, ]
  hex_sf$hex_id <- seq_len(nrow(hex_sf))

  if (!is.na(original_crs)) {
    hex_sf <- sf::st_transform(hex_sf, original_crs)
  }

  hex_sf
}


#' Attach per-hexagon area, inner diameter, and study-area coverage
#'
#' Run this once after \code{make_hex_grid()} and cache the result.  All
#' downstream functions skip recomputation when the three columns are present.
#'
#' Adds three columns to \code{hex_grid}:
#' \describe{
#'   \item{hex_area_m2}{Hexagon area in square metres.}
#'   \item{hex_inner_diameter_m}{Inner (flat-to-flat) diameter in metres,
#'     used for proportional circle scaling in plots.}
#'   \item{study_area_coverage}{Fraction of the hexagon that lies inside
#'     \code{study_area} (0–1).}
#' }
#'
#' @param hex_grid   \code{sf} polygon grid from \code{make_hex_grid()}.
#' @param study_area \code{sf} polygon defining the study boundary.
#' @return \code{hex_grid} with the three extra columns appended.
#' @export
precompute_hex_metadata <- function(hex_grid, study_area) {
  stopifnot(inherits(hex_grid,   "sf"))
  stopifnot(inherits(study_area, "sf"))

  study_area <- sf::st_transform(study_area, sf::st_crs(hex_grid))

  # Per-hexagon area and inner diameter
  hex_area_m2      <- as.numeric(sf::st_area(hex_grid))
  # Inner diameter = 2 × inradius; for a regular hexagon: inradius = sqrt(3)/2 × side
  # Equivalently: inner_diameter = 2 × sqrt(area / (2 × sqrt(3)))
  hex_inner_diam_m <- 2 * sqrt(hex_area_m2 / (2 * sqrt(3)))

  hex_grid$hex_area_m2          <- hex_area_m2
  hex_grid$hex_inner_diameter_m <- hex_inner_diam_m

  # Study-area coverage fraction
  message("Precomputing study_area_coverage for ", nrow(hex_grid),
          " hexagons — this runs once.")

  study_union <- sf::st_union(study_area)

  inside_area <- suppressWarnings(
    sf::st_intersection(
      hex_grid["hex_id"],
      sf::st_sf(geometry = study_union)
    )
  ) %>%
    dplyr::mutate(.inside_area = as.numeric(sf::st_area(geometry))) %>%
    sf::st_drop_geometry() %>%
    dplyr::group_by(hex_id) %>%
    dplyr::summarise(.inside_area = sum(.inside_area, na.rm = TRUE),
                     .groups = "drop")

  hex_grid %>%
    dplyr::left_join(inside_area, by = "hex_id") %>%
    dplyr::mutate(
      .inside_area        = dplyr::coalesce(.inside_area, 0),
      study_area_coverage = .inside_area / hex_area_m2
    ) %>%
    dplyr::select(-.inside_area)
}


#' Assign each survey point its containing hexagon ID
#'
#' Returns \code{survey_sf} with a new integer \code{hex_id} column.  Points
#' that do not fall within any hexagon receive \code{NA}.  Because the hex grid
#' is fixed across an entire analysis run, this join only needs to happen once.
#'
#' @param survey_sf An \code{sf} POINT object of all survey locations.
#' @param hex_grid  The hexagon grid (must already have a \code{hex_id}
#'   column).
#' @return \code{survey_sf} with \code{hex_id} appended.
#' @export
precompute_survey_hex_id <- function(survey_sf, hex_grid) {
  stopifnot(inherits(survey_sf, "sf"))
  stopifnot(inherits(hex_grid,  "sf"))
  stopifnot("hex_id" %in% names(hex_grid))

  message("Precomputing survey–hexagon spatial join for ",
          nrow(survey_sf), " surveys — this runs once.")

  if (sf::st_crs(survey_sf) != sf::st_crs(hex_grid)) {
    survey_sf <- sf::st_transform(survey_sf, sf::st_crs(hex_grid))
  }

  joined <- sf::st_join(
    survey_sf,
    hex_grid["hex_id"],
    join = sf::st_within,
    left = TRUE   # keep all surveys; unmatched receive NA hex_id
  )

  # sf::st_join may suffix the column name if hex_id already existed
  if ("hex_id.y" %in% names(joined)) {
    joined <- joined %>%
      dplyr::select(-dplyr::any_of("hex_id.x")) %>%
      dplyr::rename(hex_id = hex_id.y)
  }

  joined
}


# ==============================================================================
# Section 5 – Cache helpers
# ==============================================================================

#' Load a cached RDS file, or compute, save, and return the result
#'
#' Optionally checks whether the cache is newer than a reference file
#' (\code{source_path}).  If the reference file is newer than the cache, the
#' cache is treated as stale and recomputed.
#'
#' @param cache_path  Path to the \code{.rds} cache file.
#' @param compute_fn  Zero-argument function that produces the object to cache.
#' @param source_path Optional path to a source file whose modification time
#'   is compared against the cache.  If the source is newer, the cache is
#'   regenerated.
#' @return The cached or freshly computed object.
load_or_compute <- function(cache_path, compute_fn, source_path = NULL) {
  cache_exists <- file.exists(cache_path)

  stale <- if (cache_exists && !is.null(source_path) &&
               file.exists(source_path)) {
    file.mtime(source_path) > file.mtime(cache_path)
  } else {
    FALSE
  }

  if (cache_exists && !stale) {
    message("Loading cached file: ", cache_path)
    return(readRDS(cache_path))
  }

  if (stale) {
    message("Cache is stale (source newer than cache): regenerating ", cache_path)
  } else {
    message("Cache not found: computing and saving to ", cache_path)
  }

  result <- compute_fn()
  saveRDS(result, cache_path)
  result
}


# ==============================================================================
# Section 6 – Per-hexagon observation and prediction summaries
# ==============================================================================

#' Summarise survey observations per hexagon
#'
#' Uses the precomputed \code{hex_id} column on \code{dat} — no spatial
#' join is performed.  Falls back to an \code{sf::st_within} join with a
#' warning if \code{hex_id} is absent.
#'
#' @param dat      \code{sf} POINT object from \code{make_sp_dat()}, already
#'   filtered to the species and date window of interest.
#' @param hex_grid \code{sf} polygon grid.
#' @return \code{hex_grid} with per-hexagon observation columns appended:
#'   \code{n_surveys}, \code{n_surveys_detected}, \code{total_count},
#'   \code{mean_count_per_effort}, \code{obs_detected}.
summarize_surveys_by_hex <- function(dat, hex_grid) {
  stopifnot(inherits(dat,      "sf"))
  stopifnot(inherits(hex_grid, "sf"))
  stopifnot("count_per_effort" %in% names(dat))
  stopifnot("count"            %in% names(dat))

  if (!"hex_id" %in% names(dat)) {
    warning(
      "hex_id column not found in `dat`. ",
      "Run precompute_survey_hex_id() once on the full survey dataset ",
      "to avoid a slow per-species spatial join."
    )
    if (sf::st_crs(dat) != sf::st_crs(hex_grid)) {
      dat <- sf::st_transform(dat, sf::st_crs(hex_grid))
    }
    dat <- sf::st_join(
      dat,
      hex_grid["hex_id"],
      join = sf::st_within,
      left = FALSE
    )
  }

  if (!"hex_id" %in% names(hex_grid)) {
    hex_grid$hex_id <- seq_len(nrow(hex_grid))
  }

  hex_obs <- dat %>%
    sf::st_drop_geometry() %>%
    dplyr::filter(!is.na(hex_id)) %>%
    dplyr::group_by(hex_id) %>%
    dplyr::summarise(
      n_surveys             = dplyr::n(),
      n_surveys_detected    = sum(count > 0, na.rm = TRUE),
      total_count           = sum(count, na.rm = TRUE),
      mean_count_per_effort = mean(count_per_effort, na.rm = TRUE),
      obs_detected          = any(count > 0, na.rm = TRUE),
      .groups = "drop"
    )

  hex_grid %>%
    dplyr::left_join(hex_obs, by = "hex_id") %>%
    dplyr::mutate(
      n_surveys             = dplyr::coalesce(n_surveys, 0L),
      n_surveys_detected    = dplyr::coalesce(n_surveys_detected, 0L),
      total_count           = dplyr::coalesce(total_count, 0),
      mean_count_per_effort = dplyr::if_else(
        n_surveys > 0, mean_count_per_effort, NA_real_
      ),
      obs_detected = dplyr::if_else(
        n_surveys > 0,
        dplyr::coalesce(obs_detected, FALSE),
        NA
      )
    )
}

compute_flag_thresholds <- function(hex_summary,
                                    core_cumprop      = 0.50,
                                    low_tail_cumprop  = 0.01,
                                    min_coverage      = 0.25) {
  
  # Work only with hexagons that have valid predictions
  dat <- hex_summary %>%
    sf::st_drop_geometry() %>%
    dplyr::filter(
      is.finite(pred_mean),
      pred_mean > 0,
      pred_coverage >= min_coverage
    )
  
  if (nrow(dat) == 0) return(list(high = NA_real_, absent = NA_real_))
  
  # Weight each hexagon by its predicted population index
  # (pred_mean x area x study_area_coverage), consistent with how
  # add_cumulative_prediction_classes() works internally
  dat <- dat %>%
    dplyr::mutate(
      pop_index = pred_mean *
        dplyr::coalesce(hex_area_m2, 1) *
        dplyr::coalesce(study_area_coverage, 1)
    )
  
  total_pop <- sum(dat$pop_index, na.rm = TRUE)
  
  dat <- dat %>%
    dplyr::arrange(dplyr::desc(pred_mean)) %>%
    dplyr::mutate(
      cum_prop = cumsum(pop_index) / total_pop
    )
  
  # High-abundance threshold: lowest pred_mean among hexagons in the
  # top core_cumprop of cumulative population (ranked high to low)
  high_threshold <- dat %>%
    dplyr::filter(dplyr::lag(cum_prop, default = 0) < core_cumprop) %>%
    dplyr::pull(pred_mean) %>%
    min(na.rm = TRUE)
  
  # Absence threshold: highest pred_mean among hexagons that collectively
  # contribute less than low_tail_cumprop of the population (ranked low
  # to high, i.e. reverse order)
  absent_threshold <- dat %>%
    dplyr::arrange(pred_mean) %>%
    dplyr::mutate(
      cum_prop_low = cumsum(pop_index) / total_pop
    ) %>%
    dplyr::filter(cum_prop_low < low_tail_cumprop) %>%
    dplyr::pull(pred_mean) %>%
    max(na.rm = TRUE)
  
  # Safety check
  if (is.finite(absent_threshold) && is.finite(high_threshold) &&
      absent_threshold >= high_threshold) {
    warning("Absence threshold >= high-abundance threshold; ",
            "falling back to 10% of high threshold.")
    absent_threshold <- high_threshold * 0.1
  }
  
  list(high = high_threshold, absent = absent_threshold)
}

#' Classify hexagons into five abundance categories via cumulative-population
#' breakpoints
#'
#' Sorts hexagons from lowest to highest \code{pred_mean} and finds the
#' \code{pred_mean} value at which cumulative population crosses each
#' proportion in \code{cumpop_breaks}.  The resulting thresholds are used
#' both for the \code{category} column (via \code{apply_thresholds()}) and
#' as the species-specific absence / high-abundance thresholds passed to
#' \code{assess_region()}.
#'
#' @param hex_summary   \code{sf} or \code{data.frame} with a \code{pred_mean}
#'   column (and optionally the column named by \code{col}).
#' @param col           Name of the abundance column to classify.
#'   Default \code{"pred_mean"}.
#' @param cumpop_breaks Named list with four numeric proportions (0–1):
#'   \describe{
#'     \item{absent_upper}{Upper edge of "Effectively Absent" — hexagons
#'       summing to this fraction of total population from the low end.}
#'     \item{low_upper}{Upper edge of "Low".}
#'     \item{mod_upper}{Upper edge of "Moderate".}
#'     \item{high_upper}{Upper edge of "High" (above = "Very High").}
#'   }
#'   Defaults to \code{list(absent_upper=0.001, low_upper=0.25,
#'   mod_upper=0.50, high_upper=0.75)}.
#' @return A named list with elements \code{absent_upper}, \code{low_upper},
#'   \code{mod_upper}, \code{high_upper}, and \code{method = "cumpop"}.
#'   The \code{absent_upper} and \code{high_upper} elements are used directly
#'   as the absence and high-abundance flag thresholds in the assess scripts.
#' @export
get_thresholds_cumpop <- function(hex_summary,
                                  col          = "pred_mean",
                                  cumpop_breaks = list(
                                    absent_upper = 0.001,
                                    low_upper    = 0.25,
                                    mod_upper    = 0.50,
                                    high_upper   = 0.75
                                  )) {

  required_names <- c("absent_upper", "low_upper", "mod_upper", "high_upper")
  missing_names  <- setdiff(required_names, names(cumpop_breaks))
  if (length(missing_names) > 0) {
    stop("cumpop_breaks is missing elements: ",
         paste(missing_names, collapse = ", "))
  }

  x <- if (inherits(hex_summary, "sf")) {
    sf::st_drop_geometry(hex_summary)[[col]]
  } else {
    hex_summary[[col]]
  }
  x <- x[!is.na(x)]

  if (length(x) == 0) {
    warning("get_thresholds_cumpop: no non-NA values in column '", col,
            "'; returning NA thresholds.")
    return(list(
      absent_upper = NA_real_,
      low_upper    = NA_real_,
      mod_upper    = NA_real_,
      high_upper   = NA_real_,
      method       = "cumpop"
    ))
  }

  total    <- sum(x)
  x_sorted <- sort(x, decreasing = FALSE)
  cum_prop <- cumsum(x_sorted) / total

  # For each breakpoint: find the smallest x_sorted value at which the
  # cumulative proportion first meets or exceeds the target.
  find_threshold <- function(target_prop) {
    idx <- which(cum_prop >= target_prop)
    if (length(idx) == 0) return(max(x_sorted))
    x_sorted[idx[1]]
  }

  absent_upper <- find_threshold(cumpop_breaks$absent_upper)
  low_upper    <- find_threshold(cumpop_breaks$low_upper)
  mod_upper    <- find_threshold(cumpop_breaks$mod_upper)
  high_upper   <- find_threshold(cumpop_breaks$high_upper)

  message(sprintf(
    paste0(
      "[Cumulative population thresholds]\n",
      "  Effectively Absent:  pred_mean \u2264 %.6f",
      "  (lowest hexagons summing to %.1f%% of total population)\n",
      "  Low:                 %.6f \u2013 %.6f",
      "  (%.1f%% \u2013 %.1f%% of cumulative population)\n",
      "  Moderate:            %.6f \u2013 %.6f",
      "  (%.1f%% \u2013 %.1f%% of cumulative population)\n",
      "  High:                %.6f \u2013 %.6f",
      "  (%.1f%% \u2013 %.1f%% of cumulative population)\n",
      "  Very High:           pred_mean > %.6f",
      "  (top hexagons comprising final %.1f%% of population)"
    ),
    absent_upper, cumpop_breaks$absent_upper * 100,
    absent_upper, low_upper,
    cumpop_breaks$absent_upper * 100, cumpop_breaks$low_upper * 100,
    low_upper,    mod_upper,
    cumpop_breaks$low_upper * 100,    cumpop_breaks$mod_upper * 100,
    mod_upper,    high_upper,
    cumpop_breaks$mod_upper * 100,    cumpop_breaks$high_upper * 100,
    high_upper,
    (1 - cumpop_breaks$high_upper) * 100
  ))

  list(
    absent_upper  = absent_upper,
    low_upper     = low_upper,
    mod_upper     = mod_upper,
    high_upper    = high_upper,
    method        = "cumpop",
    cumpop_breaks = cumpop_breaks
  )
}


#' Apply cumulative-population thresholds to a hex summary
#'
#' Adds a factor column (default name \code{"category"}) with five ordered
#' levels: Effectively Absent, Low, Moderate, High, Very High.  The column
#' is \code{NA} where \code{col} is \code{NA}.
#'
#' @param hex_summary  \code{sf} or \code{data.frame} from \code{summarize_hex()}.
#' @param thresholds   List returned by \code{get_thresholds_cumpop()}.
#' @param col          Name of the column to classify. Default \code{"pred_mean"}.
#' @param out_col      Name of the new category column. Default \code{"category"}.
#' @return \code{hex_summary} with \code{out_col} appended as an ordered factor.
#' @export
apply_thresholds <- function(hex_summary,
                             thresholds,
                             col     = "pred_mean",
                             out_col = "category") {

  required_thresholds <- c("absent_upper", "low_upper", "mod_upper", "high_upper")
  missing_t <- setdiff(required_thresholds, names(thresholds))
  if (length(missing_t) > 0) {
    stop("thresholds is missing elements: ", paste(missing_t, collapse = ", "))
  }

  x <- if (inherits(hex_summary, "sf")) {
    sf::st_drop_geometry(hex_summary)[[col]]
  } else {
    hex_summary[[col]]
  }

  cats <- dplyr::case_when(
    is.na(x)                          ~ NA_character_,
    x <= thresholds$absent_upper      ~ "Effectively Absent",
    x <  thresholds$low_upper         ~ "Low",
    x <  thresholds$mod_upper         ~ "Moderate",
    x <  thresholds$high_upper        ~ "High",
    TRUE                              ~ "Very High"
  )

  hex_summary[[out_col]] <- factor(
    cats,
    levels = c(
      "Effectively Absent",
      "Low",
      "Moderate",
      "High",
      "Very High"
    )
  )

  hex_summary
}


#' Extract raster model predictions into each hexagon
#'
#' Uses \code{exactextractr} for fast polygon–raster extraction.  Falls back
#' to \code{terra::extract} if \code{exactextractr} is not installed.
#'
#' Computes \code{pred_mean} (mean over non-NA pixels) and
#' \code{pred_coverage} (fraction of hexagon pixels with raster data).
#' Hexagons below \code{min_coverage} receive \code{pred_mean = NA}.
#'
#' @param hex_grid     \code{sf} polygon grid.
#' @param rast         \code{SpatRaster} of model predictions.
#' @param rast_max_q   Upper quantile for outlier suppression. Default 0.99.
#' @param min_coverage Minimum raster coverage fraction for \code{pred_mean}
#'   to be reported. Default 0.25.
#' @return \code{hex_grid} with \code{pred_mean} and \code{pred_coverage}
#'   columns appended.
extract_hex_predictions <- function(hex_grid,
                                    rast,
                                    min_coverage = 0.25) {
  stopifnot(inherits(hex_grid, "sf"))
  stopifnot(inherits(rast,     "SpatRaster"))
  stopifnot(is.numeric(min_coverage), min_coverage >= 0, min_coverage <= 1)

  hex_proj  <- sf::st_transform(hex_grid, terra::crs(rast))
  rast_crop <- terra::crop(rast, terra::vect(hex_proj))

  if (requireNamespace("exactextractr", quietly = TRUE)) {

    # exactextractr: use coverage_weight = FALSE so each pixel contributes
    # equally (equivalent to terra's fun = mean, na.rm = TRUE).
    pred_vals <- exactextractr::exact_extract(
      rast_crop, hex_proj,
      fun           = "mean",
      default_value = NA_real_,
      progress      = FALSE
    )

    # Coverage: mean of a binary raster (1 = has data, 0 = NA)
    rast_covered <- terra::ifel(is.na(rast_crop), 0L, 1L)
    cov_vals <- exactextractr::exact_extract(
      rast_covered, hex_proj,
      fun      = "mean",
      progress = FALSE
    )

  } else {

    message("exactextractr not found — falling back to terra::extract (slower).")

    pred_ex   <- terra::extract(rast_crop, terra::vect(hex_proj),
                                fun = mean, na.rm = TRUE)
    pred_vals <- pred_ex[[2]]

    rast_covered <- !is.na(rast_crop)
    cov_ex   <- terra::extract(rast_covered, terra::vect(hex_proj),
                               fun = mean, na.rm = TRUE)
    cov_vals <- cov_ex[[2]]
  }

  hex_grid %>%
    dplyr::mutate(
      pred_coverage = dplyr::if_else(
        is.finite(cov_vals), as.numeric(cov_vals), 0
      ),
      pred_mean = dplyr::if_else(
        is.finite(pred_vals) & cov_vals >= min_coverage,
        as.numeric(pred_vals),
        NA_real_
      )
    )
}


#' Combine per-hexagon observation and prediction summaries
#'
#' @inheritParams summarize_surveys_by_hex
#' @inheritParams extract_hex_predictions
#' @param pred_presence_threshold Predictions at or below this value are
#'   treated as predicted-absent. Default 0.
#' @return \code{hex_grid} with all observation and prediction columns, plus
#'   a logical \code{pred_detected} column.
summarize_hex <- function(dat,
                          hex_grid,
                          rast,
                          pred_presence_threshold = 0,
                          min_coverage            = 0.25) {

  hex_obs  <- summarize_surveys_by_hex(dat, hex_grid)

  hex_full <- extract_hex_predictions(
    hex_obs,
    rast,
    min_coverage = min_coverage
  )

  hex_full %>%
    dplyr::mutate(
      pred_detected = dplyr::if_else(
        is.finite(pred_mean) & pred_mean > pred_presence_threshold,
        TRUE, FALSE
      )
    )
}


# ==============================================================================
# Section 7 – Study-area coverage (backward-compatibility helper)
# ==============================================================================

#' Add study-area coverage fraction to a hex summary
#'
#' This function is retained for backward compatibility and for grids that
#' have not been through \code{precompute_hex_metadata()}.  It is a no-op
#' when \code{study_area_coverage} is already present.
add_study_area_coverage <- function(hex_summary,
                                    study_area,
                                    coverage_col = "study_area_coverage") {

  if (coverage_col %in% names(hex_summary)) return(hex_summary)

  stopifnot(inherits(hex_summary, "sf"))
  stopifnot(inherits(study_area,  "sf"))
  stopifnot("hex_id" %in% names(hex_summary))

  study_area  <- sf::st_transform(study_area, sf::st_crs(hex_summary))
  study_union <- sf::st_union(study_area)

  hex_area <- hex_summary %>%
    dplyr::mutate(.hex_area = as.numeric(sf::st_area(geometry))) %>%
    sf::st_drop_geometry() %>%
    dplyr::select(hex_id, .hex_area)

  inside_area <- suppressWarnings(
    sf::st_intersection(
      hex_summary["hex_id"],
      sf::st_sf(geometry = study_union)
    )
  ) %>%
    dplyr::mutate(.inside_area = as.numeric(sf::st_area(geometry))) %>%
    sf::st_drop_geometry() %>%
    dplyr::group_by(hex_id) %>%
    dplyr::summarise(.inside_area = sum(.inside_area, na.rm = TRUE),
                     .groups = "drop")

  hex_summary %>%
    dplyr::left_join(hex_area,    by = "hex_id") %>%
    dplyr::left_join(inside_area, by = "hex_id") %>%
    dplyr::mutate(
      .inside_area = dplyr::coalesce(.inside_area, 0),
      "{coverage_col}" := .inside_area / .hex_area
    ) %>%
    dplyr::select(-.hex_area, -.inside_area)
}


