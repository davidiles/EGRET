#' Compute Spearman correlation between predictions and observations
#'
#' Restricted to hexagons that are surveyed, have a finite prediction, and
#' have a prediction above \code{absence_threshold} (i.e., not model-absent).
compute_filtered_spearman <- function(hex_summary, absence_threshold) {

  cor_dat <- hex_summary %>%
    sf::st_drop_geometry() %>%
    dplyr::filter(
      n_surveys > 0,
      is.finite(mean_count_per_effort),
      is.finite(pred_mean),
      pred_mean > absence_threshold
    )

  if (nrow(cor_dat) >= 3) {
    stats::cor(
      cor_dat$pred_mean,
      cor_dat$mean_count_per_effort,
      use    = "complete.obs",
      method = "spearman"
    )
  } else {
    NA_real_
  }
}


#' Compute region-wide model-validation statistics
#'
#' @param hex_summary     Output of \code{summarize_hex()} after flag columns
#'   have been attached (i.e., after \code{plot_hex_pred_obs()} has been called
#'   and its \code{hex_summary} element extracted).
#' @param absence_threshold Numeric. Prediction value at or below which a
#'   hexagon is considered model-predicted absent.
#' @return A one-row \code{data.frame}.
#' @export
compute_region_stats <- function(hex_summary, absence_threshold) {

  required_cols <- c(
    "n_surveys", "obs_detected",
    "mean_count_per_effort", "pred_mean",
    "pred_coverage", "study_area_coverage",
    "flag_high_pred_no_detection", "flag_pred_absent_detected"
  )
  missing_cols <- setdiff(required_cols, names(hex_summary))
  if (length(missing_cols) > 0) {
    stop("hex_summary is missing columns: ",
         paste(missing_cols, collapse = ", "))
  }

  dat      <- hex_summary %>% sf::st_drop_geometry()
  surveyed <- dat %>% dplyr::filter(n_surveys > 0)
  covered  <- dat %>% dplyr::filter(is.finite(pred_mean))

  surveyed_covered       <- surveyed %>% dplyr::filter(is.finite(pred_mean))
  surveyed_above_absence <- surveyed %>%
    dplyr::filter(is.finite(pred_mean), pred_mean > absence_threshold)

  n_hex_total              <- nrow(dat)
  n_hex_pred_covered       <- nrow(covered)
  n_hex_surveyed           <- nrow(surveyed)
  n_hex_surveyed_covered   <- nrow(surveyed_covered)
  n_hex_surveyed_above_absence <- nrow(surveyed_above_absence)

  n_hex_detected  <- sum(surveyed$obs_detected, na.rm = TRUE)
  n_surveys_total <- sum(surveyed$n_surveys,    na.rm = TRUE)

  n_flag_high_pred_no_detection <- sum(
    dat$flag_high_pred_no_detection, na.rm = TRUE
  )
  n_flag_pred_absent_detected <- sum(
    dat$flag_pred_absent_detected, na.rm = TRUE
  )
  n_flag_any <- sum(
    dat$flag_high_pred_no_detection | dat$flag_pred_absent_detected,
    na.rm = TRUE
  )

  spearman_obs_pred_above_absence <- compute_filtered_spearman(
    hex_summary       = hex_summary,
    absence_threshold = absence_threshold
  )

  data.frame(
    n_hex_total                  = n_hex_total,
    n_hex_pred_covered           = n_hex_pred_covered,
    prop_hex_pred_covered        = n_hex_pred_covered / n_hex_total,

    n_hex_surveyed               = n_hex_surveyed,
    n_hex_surveyed_covered       = n_hex_surveyed_covered,
    prop_surveyed_covered        = if (n_hex_surveyed > 0)
      n_hex_surveyed_covered / n_hex_surveyed else NA_real_,

    n_hex_surveyed_above_absence = n_hex_surveyed_above_absence,

    n_surveys_total              = n_surveys_total,
    mean_surveys_per_hex         = if (n_hex_surveyed > 0)
      n_surveys_total / n_hex_surveyed else NA_real_,

    n_hex_detected               = n_hex_detected,
    prop_hex_detected            = if (n_hex_surveyed > 0)
      n_hex_detected / n_hex_surveyed else NA_real_,

    spearman_obs_pred_above_absence = spearman_obs_pred_above_absence,
    absence_threshold            = absence_threshold,

    n_flag_high_pred_no_detection = n_flag_high_pred_no_detection,
    n_flag_pred_absent_detected   = n_flag_pred_absent_detected,
    n_flag_any                    = n_flag_any,

    prop_surveyed_flagged        = if (n_hex_surveyed > 0)
      n_flag_any / n_hex_surveyed else NA_real_,

    prop_detected_in_pred_absent = if (n_hex_detected > 0)
      n_flag_pred_absent_detected / n_hex_detected else NA_real_
  )
}


