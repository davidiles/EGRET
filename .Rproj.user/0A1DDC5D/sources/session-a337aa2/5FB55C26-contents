#' Assess model predictions against survey observations at any spatial scale
#'
#' Performance notes
#' -----------------
#' For large national grids (80,000+ hexagons) run across many species, call
#' \code{precompute_hex_metadata()} and \code{precompute_survey_hex_id()} once
#' before entering the species loop.  This eliminates the two most expensive
#' per-species operations (study-area coverage intersection and the
#' survey–hexagon spatial join).
#'
#' @param region       \code{sf} polygon defining the assessment boundary.
#' @param sp_dat       \code{sf} POINT object of species-specific survey data
#'   (output of \code{make_sp_dat()} filtered to the date window).
#' @param rast         \code{SpatRaster} of model predictions.
#' @param hex_grid     Pre-built hexagon grid, ideally after
#'   \code{precompute_hex_metadata()}.
#' @inheritParams plot_hex_pred_obs
#' @return A list: \code{plot_combined}, \code{hex_summary},
#'   \code{region_stats}, \code{flag_thresholds}.
#' @export
assess_region <- function(region,
                          sp_dat,
                          rast,
                          hex_grid                        = NULL,
                          hex_summary_precomputed         = NULL,
                          n_hexagons                      = 1000,
                          water                           = NULL,
                          rast_max_q                      = 0.99,
                          transform                       = "identity",
                          pred_presence_threshold         = 0,
                          min_coverage                    = 0.25,
                          min_study_area_coverage         = 0.50,
                          flag_high_pred_cumprop          = 0.50,
                          flag_high_pred_threshold        = NULL,
                          flag_high_pred_min_surveys      = 50,
                          flag_high_pred_effort_quantile  = NULL,
                          flag_absence_fraction_of_high   = 0.01,
                          flag_absence_threshold          = NULL,
                          flag_absence_min_surveys        = 1,
                          flag_absence_effort_quantile    = NULL,
                          flag_col_high_pred_no_detection = "#0072B2",
                          flag_col_pred_absent_detected   = "orangered",
                          flag_linewidth                  = 0.2,
                          title                           = NULL,
                          model_source                    = NULL,
                          data_source                     = NULL) {

  stopifnot(inherits(region, "sf"))
  stopifnot(inherits(sp_dat, "sf"))
  stopifnot(inherits(rast,   "SpatRaster"))
  if (!is.null(hex_grid)) stopifnot(inherits(hex_grid, "sf"))

  region <- sf::st_transform(region, sf::st_crs(sp_dat))
  sp_dat <- sf::st_filter(sp_dat, region, .predicate = sf::st_intersects)

  region_vect  <- region %>%
    sf::st_transform(terra::crs(rast)) %>%
    terra::vect()

  rast_cropped <- rast %>%
    terra::crop(region_vect) %>%
    terra::mask(region_vect)

  if (is.null(hex_grid)) {
    hex_grid <- make_hex_grid(region, n_hexagons = n_hexagons)
  }

  hex_summary <- if (!is.null(hex_summary_precomputed)) {
    hex_summary_precomputed
  } else {
    summarize_hex(
      dat                     = sp_dat,
      hex_grid                = hex_grid,
      rast                    = rast_cropped,
      rast_max_q              = rast_max_q,
      pred_presence_threshold = pred_presence_threshold,
      min_coverage            = min_coverage
    )
  }

  # No-op if study_area_coverage is already present from precomputation
  hex_summary <- add_study_area_coverage(hex_summary, region)

  p_hex <- plot_hex_pred_obs(
    hex_summary                     = hex_summary,
    rast                            = rast_cropped,
    study_area                      = region,
    water                           = water,
    rast_max_q                      = rast_max_q,
    transform                       = transform,
    min_coverage                    = min_coverage,
    min_study_area_coverage         = min_study_area_coverage,
    flag_high_pred_cumprop          = flag_high_pred_cumprop,
    flag_high_pred_threshold        = flag_high_pred_threshold,
    flag_high_pred_min_surveys      = flag_high_pred_min_surveys,
    flag_high_pred_effort_quantile  = flag_high_pred_effort_quantile,
    flag_absence_fraction_of_high   = flag_absence_fraction_of_high,
    flag_absence_threshold          = flag_absence_threshold,
    flag_absence_min_surveys        = flag_absence_min_surveys,
    flag_absence_effort_quantile    = flag_absence_effort_quantile,
    flag_col_high_pred_no_detection = flag_col_high_pred_no_detection,
    flag_col_pred_absent_detected   = flag_col_pred_absent_detected,
    flag_linewidth                  = flag_linewidth
  )

  hex_summary  <- p_hex$hex_summary

  region_stats <- compute_region_stats(
    hex_summary       = hex_summary,
    absence_threshold = p_hex$flag_thresholds$absence_threshold
  )

  p_honey <- plot_honeycomb(
    hex_summary = hex_summary,
    study_area  = region,
    water       = water
  )

  margin_theme <- ggplot2::theme(
    plot.margin = ggplot2::margin(5, 10, 5, 10)
  )

  combined <- patchwork::wrap_plots(
    list(p_hex$plot + margin_theme, p_honey + margin_theme),
    ncol = 2
  )

  if (!is.null(title) || !is.null(model_source) || !is.null(data_source)) {
    subtitle <- NULL
    if (!is.null(model_source) || !is.null(data_source)) {
      parts <- c(
        if (!is.null(model_source)) paste("Model:", model_source),
        if (!is.null(data_source))  paste("Data:",  data_source)
      )
      subtitle <- paste(parts, collapse = "   |   ")
    }
    combined <- combined +
      patchwork::plot_annotation(
        title    = title,
        subtitle = subtitle,
        theme    = ggplot2::theme(
          plot.title    = ggplot2::element_text(size = 18, face = "bold",
                                                margin = ggplot2::margin(b = 2)),
          plot.subtitle = ggplot2::element_text(size = 12, colour = "grey30",
                                                margin = ggplot2::margin(b = 6))
        )
      )
  }

  list(
    plot_combined   = combined,
    hex_summary     = hex_summary,
    region_stats    = region_stats,
    flag_thresholds = p_hex$flag_thresholds
  )
}


# ==============================================================================
# Section 11 – Water-layer helpers
# ==============================================================================

process_water <- function(study_area,
                          water,
                          target_crs = paste0(
                            "+proj=lcc +lat_1=49 +lat_2=77 +lat_0=49",
                            " +lon_0=-95 +datum=NAD83 +units=km +no_defs"
                          ),
                          area_breaks_km2        = c(25e3, 250e3),
                          simplify_tolerances_km = c(fine   = 0.05,
                                                     medium = 1,
                                                     coarse = 10)) {
  stopifnot(inherits(study_area, "sf"))
  stopifnot(inherits(water,      "sf"))

  study_area <- sf::st_transform(study_area, target_crs)
  water      <- sf::st_transform(water,      target_crs)

  study_area_union <- sf::st_union(study_area)
  water_sub <- water %>%
    sf::st_crop(sf::st_bbox(study_area)) %>%
    sf::st_filter(study_area_union, .predicate = sf::st_intersects)

  water_layers <- list(
    fine   = sf::st_simplify(water_sub,
                             dTolerance       = simplify_tolerances_km[["fine"]],
                             preserveTopology = TRUE),
    medium = sf::st_simplify(water_sub,
                             dTolerance       = simplify_tolerances_km[["medium"]],
                             preserveTopology = TRUE),
    coarse = sf::st_simplify(water_sub,
                             dTolerance       = simplify_tolerances_km[["coarse"]],
                             preserveTopology = TRUE)
  )

  structure(
    list(
      water_layers    = water_layers,
      study_area      = study_area,
      region_area_km2 = as.numeric(sf::st_area(study_area_union)),
      area_breaks_km2 = area_breaks_km2,
      crs             = sf::st_crs(study_area)
    ),
    class = c("processed_water", "list")
  )
}


resolve_water_layer <- function(water, study_area) {
  region_area_km2 <- as.numeric(sf::st_area(sf::st_union(study_area)))
  detail <- dplyr::case_when(
    region_area_km2 < water$area_breaks_km2[1] ~ "fine",
    region_area_km2 < water$area_breaks_km2[2] ~ "medium",
    TRUE                                        ~ "coarse"
  )
  water$water_layers[[detail]] %>%
    sf::st_crop(study_area) %>%
    sf::st_filter(study_area, .predicate = sf::st_intersects) %>%
    sf::st_intersection(study_area)
}


